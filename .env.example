# Country Compare API deployment example
# Copy to .env and edit values for your environment.

# Backend API
COUNTRY_COMPARE_API_PORT=8000
COUNTRY_COMPARE_API_ENABLE_DOCS=false
# Set to an empty value to disable CORS origins for backend-only deployments.
COUNTRY_COMPARE_API_CORS_ORIGINS=http://localhost:8501
COUNTRY_COMPARE_API_KEY=
COUNTRY_COMPARE_API_LOG_LEVEL=INFO
# Optional platform-injected container port. Leave unset locally unless needed.
PORT=8000

# Request/response guardrails
COUNTRY_COMPARE_API_MAX_RECORDS=500
COUNTRY_COMPARE_API_MAX_COUNTRIES=50
COUNTRY_COMPARE_API_MAX_METRICS=50
COUNTRY_COMPARE_API_MAX_HORIZON_YEARS=10
COUNTRY_COMPARE_API_MAX_HOLDOUT_YEARS=10
COUNTRY_COMPARE_API_MAX_TOP_N=100

# Dataset/config settings used by the app
COUNTRY_COMPARE_STORE_BACKEND=parquet
COUNTRY_COMPARE_STORE_PATH=data/processed/metrics.parquet
COUNTRY_COMPARE_METRICS_CONFIG=config/metrics.yaml
COUNTRY_COMPARE_SCORING_CONFIG=config/scoring_profiles.yaml

# Optional app/runtime settings
COUNTRY_COMPARE_DEBUG=false
COUNTRY_COMPARE_AUDIT_DIR=data/audit
COUNTRY_COMPARE_EXPORT_DIR=data/exports
COUNTRY_COMPARE_PREDICTION_METHOD=linear_trend
COUNTRY_COMPARE_PREDICTION_FALLBACK_METHOD=last_observed
COUNTRY_COMPARE_MAX_PREDICTION_HORIZON=10
