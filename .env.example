# Country Compare API deployment example
# Copy to .env and edit values for your environment.

# Backend API
COUNTRY_COMPARE_API_URL=http://backend:8000
COUNTRY_COMPARE_API_PORT=8000
COUNTRY_COMPARE_API_ENABLE_DOCS=false

# Set to an empty value to disable CORS origins for backend-only deployments.
COUNTRY_COMPARE_API_CORS_ORIGINS=http://localhost:8501
COUNTRY_COMPARE_API_KEY=
COUNTRY_COMPARE_API_LOG_LEVEL=INFO

# Optional platform-injected container port. Leave unset locally unless needed.
PORT=8000

# Runtime environment: development, test, staging, production.
# Production fails closed when auth is required and COUNTRY_COMPARE_API_KEY is empty.
COUNTRY_COMPARE_API_ENV=development
COUNTRY_COMPARE_API_AUTH_REQUIRED=false

# API docs and OpenAPI exposure.
COUNTRY_COMPARE_API_ENABLE_DOCS=true
COUNTRY_COMPARE_API_PROTECT_DOCS=false

# Prometheus-compatible metrics endpoint.
COUNTRY_COMPARE_API_ENABLE_METRICS=true
COUNTRY_COMPARE_API_PROTECT_METRICS=false

# Runtime auth path policy.
COUNTRY_COMPARE_API_PROTECTED_PREFIXES=/api/v1,/ready
COUNTRY_COMPARE_API_PUBLIC_PATHS=/health,/docs,/redoc,/openapi.json

# API logging.
COUNTRY_COMPARE_API_LOG_FORMAT=json
COUNTRY_COMPARE_API_CONFIGURE_LOGGING=true
COUNTRY_COMPARE_API_LOG_PROPAGATE=true
COUNTRY_COMPARE_API_LOG_CLEAR_HANDLERS=false

# Request/response guardrails
COUNTRY_COMPARE_API_MAX_RECORDS=500
COUNTRY_COMPARE_API_MAX_COUNTRIES=50
COUNTRY_COMPARE_API_MAX_METRICS=50
COUNTRY_COMPARE_API_MAX_HORIZON_YEARS=10
COUNTRY_COMPARE_API_MAX_HOLDOUT_YEARS=10
COUNTRY_COMPARE_API_MAX_TOP_N=100

# Dataset/config settings used by the app
COUNTRY_COMPARE_STORE_BACKEND=parquet
COUNTRY_COMPARE_STORE_PATH=data/processed/metrics.parquet
COUNTRY_COMPARE_METRICS_CONFIG=config/metrics.yaml
COUNTRY_COMPARE_SCORING_CONFIG=config/scoring_profiles.yaml

# Directory-level defaults. Specific path variables below override these.
COUNTRY_COMPARE_CONFIG_DIR=config
COUNTRY_COMPARE_DATA_DIR=data

# Optional app/runtime settings
COUNTRY_COMPARE_DEBUG=false
COUNTRY_COMPARE_AUDIT_DIR=data/audit
COUNTRY_COMPARE_EXPORT_DIR=data/exports
COUNTRY_COMPARE_PREDICTION_METHOD=linear_trend
COUNTRY_COMPARE_PREDICTION_FALLBACK_METHOD=last_observed
COUNTRY_COMPARE_MAX_PREDICTION_HORIZON=10

# Optional LLM forecast integration.
# Disabled by default. Enable only when the private llm-forecast service is configured.
COUNTRY_COMPARE_ENABLE_LLM_FORECAST=false
COUNTRY_COMPARE_LLM_PROVIDER=mistral
COUNTRY_COMPARE_LLM_MODEL=mistral-large-latest
COUNTRY_COMPARE_LLM_SERVICE_URL=http://llm-forecast:8080
COUNTRY_COMPARE_LLM_SERVICE_TOKEN=
COUNTRY_COMPARE_LLM_SERVICE_TIMEOUT_SECONDS=25
COUNTRY_COMPARE_LLM_MAX_SERIES_PER_REQUEST=3
COUNTRY_COMPARE_LLM_BASELINE_METHOD=holt_linear
COUNTRY_COMPARE_LLM_MAX_HISTORY_POINTS=40
COUNTRY_COMPARE_LLM_MAX_ADJUSTMENT_PCT=20.0

# Private LLM forecast microservice.
# Do not commit real secrets.
LLM_PROVIDER=mistral
LLM_SERVICE_TOKEN=
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# Local/private deployment settings.
LLM_DEPLOYMENT_PROFILE=local
LLM_REQUIRE_ZDR=false
MISTRAL_ZDR_CONFIRMED=false

# LLM service cost and request limits.
LLM_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=0
LLM_TEMPERATURE=0
LLM_MAX_OUTPUT_TOKENS=800
LLM_MAX_SERIES_PER_REQUEST=3
LLM_MAX_HORIZON_YEARS=10
LLM_MAX_HISTORY_POINTS=80
LLM_MAX_INPUT_CHARS=12000
LLM_MAX_ADJUSTMENT_PCT=15.0

# Diagnostics.
# Payload logging is forced off for public deployments.
LLM_LOG_LEVEL=INFO
LLM_DEBUG_LOG_PAYLOADS=false